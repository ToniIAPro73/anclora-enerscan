generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Assessment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Objective
  objective String? // "know", "target", "sell"

  // Property Data
  propertyType String?
  orientation  String?
  roofType     String?
  year         Int
  area         Float
  zipcode      String

  // Systems
  heating          String?
  cooling          String?
  waterHeating     String?
  ventilation      String?
  windows          String?
  renewables       String?
  facadeInsulation String?
  roofInsulation   String?
  budgetRange      String?
  timelineHorizon  String?
  targetLetter     String?
  isDemo           Boolean @default(false)

  // Scoring Results
  score           Float?
  estimatedLetter String
  confidence      String
  climateZone     String?
  penalties       String? // JSON string
  strengths       String? // JSON string
  missingData     String? // JSON string
  explanation     String?

  // Status
  isPremium        Boolean                @default(false)
  attachments      AssessmentAttachment[]
  leads            Lead[]
  costEstimateRuns EstimateRun[]
}

model AssessmentAttachment {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  name         String
  type         String
  category     String? // CEE, INTERIOR, EXTERIOR, OTHER
  size         Int
  path         String
  createdAt    DateTime   @default(now())

  ocrStatus      String    @default("pending") // pending, processing, done, failed, skipped
  ocrData        Json?
  ocrProcessedAt DateTime?
  ocrError       String?
}

model Provider {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  legalName   String?
  taxId       String?
  contactName String?
  email       String?
  phone       String?
  website     String?

  categories     String // JSON string array
  zones          String // JSON string array
  certifications String? // JSON string array

  status   String  @default("PENDING") // PENDING, VERIFIED, PREFERRED, SUSPENDED, EXCLUSIVE
  verified Boolean @default(false)
  rating   Float   @default(4.5)
  slaHours Int?

  commissionType    String? // NONE, LEAD_FEE, SUCCESS_FEE, SUBSCRIPTION, HYBRID
  commissionRate    Float?
  leadFeeCents      Int?
  monthlyFeeCents   Int?
  attributionMonths Int     @default(12)

  notes  String?
  source String? // manual, partner, inbound, internal

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  leads Lead[]
}

model Partner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  type    String  @default("REAL_ESTATE") // REAL_ESTATE, PROVIDER_REFERRER, AGENCY, CONSULTANT, INTERNAL
  company String?
  email   String?
  phone   String?
  website String?

  status            String @default("ACTIVE") // ACTIVE, PAUSED, SUSPENDED
  attributionMonths Int    @default(12)

  defaultCommissionRate Float? // percentage over net revenue, e.g. 25
  notes                 String?

  providers Provider[]
  leads     Lead[]
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  providerId String?
  provider   Provider? @relation(fields: [providerId], references: [id])

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  userName  String?
  userEmail String?
  userPhone String?

  requestedService String? // CEE, AUDIT, WINDOWS, INSULATION, HVAC, SOLAR, REFORM, REAL_ESTATE_VALUATION, OTHER
  estimatedBudget  String?
  urgency          String? // LOW, MEDIUM, HIGH, IMMEDIATE
  zone             String?

  source               String? // assessment, demo, partner, manual, provider_marketplace
  attributionOwner     String? // ANCLORA, PARTNER, PROVIDER, SHARED
  attributionExpiresAt DateTime?

  status           String @default("PENDING") // PENDING, CONTACTED, QUOTED, WON, LOST, CANCELLED
  commissionStatus String @default("NOT_APPLICABLE") // NOT_APPLICABLE, PENDING, PAYABLE, PAID, DISPUTED

  expectedValueCents Int?
  closedValueCents   Int?
  commissionCents    Int?

  consentAccepted Boolean @default(false)
  notes           String?
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  assessments         Assessment[]
  leads               Lead[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceSource {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  providerType String
  sourceKind   String
  versionLabel String?
  region       String?
  url          String?
  licenseNote  String?
  reliability  String
  capturedAt   DateTime?
  validFrom    DateTime?
  validTo      DateTime?
  notes        String?

  items PriceItem[]
}

model PriceItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guid     String      @unique
  sourceId String
  source   PriceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  code         String
  externalCode String?
  title        String
  description  String?
  unit         String
  minUnitPrice Float
  midUnitPrice Float?
  maxUnitPrice Float
  currency     String  @default("EUR")
  region       String?
  category     String
  applicableTo String
  tags         String
  confidence   String
  isActive     Boolean @default(true)

  mappings MeasurePriceMap[]
}

model EnergyMeasure {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guid                 String  @unique
  code                 String  @unique
  title                String
  description          String?
  category             String
  impactArea           String
  defaultPriority      String
  complexity           String
  typicalLetterGainMin Int?
  typicalLetterGainMax Int?
  isActive             Boolean @default(true)

  priceMappings MeasurePriceMap[]
}

model MeasurePriceMap {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  measureId       String
  priceItemId     String
  quantityFormula String
  defaultFactor   Float   @default(1.0)
  minFactor       Float?
  maxFactor       Float?
  notes           String?

  measure   EnergyMeasure @relation(fields: [measureId], references: [id], onDelete: Cascade)
  priceItem PriceItem     @relation(fields: [priceItemId], references: [id], onDelete: Cascade)
}

model EstimateRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  scenarioId       String?
  scenarioTitle    String?
  propertyType     String?
  profile          String?
  letterGainTarget Int?

  currency      String  @default("EUR")
  minTotal      Float
  midTotal      Float?
  maxTotal      Float
  confidence    String
  sourceSummary String?
  assumptions   String
  disclaimer    String

  lines EstimateLine[]
}

model EstimateLine {
  id            String      @id @default(cuid())
  estimateRunId String
  estimateRun   EstimateRun @relation(fields: [estimateRunId], references: [id], onDelete: Cascade)

  measureCode   String
  priceItemCode String
  title         String
  unit          String
  quantity      Float
  minUnitPrice  Float
  midUnitPrice  Float?
  maxUnitPrice  Float
  minSubtotal   Float
  midSubtotal   Float?
  maxSubtotal   Float
  sourceLabel   String?
  confidence    String
  assumptions   String?
}
